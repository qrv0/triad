# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.venv/
venv/

# Outputs (regenerable training outputs are ignored, but result reports kept)
outputs/**/ckpt_*.pt
outputs/**/ckpt_*.safetensors
outputs/tinyshakespeare/
outputs/tinyshakespeare_compare/
*.npz
*.h5
!tests/fixtures/*.npz

# Keep the reports and history JSONs (they document published results)
!outputs/**/*.md
!outputs/**/history.json
!outputs/**/raw_results.json

# Keep enwik8 small (downloaded on first run, large file)
experiments/neural/enwik8
experiments/neural/enwik8.zip

# Keep the small TinyShakespeare data file (1MB, downloaded once, useful for tests)
# experiments/neural/tinyshakespeare.txt — keep this committed for offline run

# IDEs
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Jupyter
.ipynb_checkpoints/
*-checkpoint.ipynb

# Tests
.coverage
.pytest_cache/
htmlcov/

# Generated figures (regenerable from experiments/)
paper/figures/*.png
paper/figures/*.pdf
!paper/figures/.gitkeep

# HuggingFace cache and staging
.cache/
.hf_staging/

# Secrets — never commit these
.env
*.token
*_token.txt
huggingface_token*
github_token*
scripts/
outputs/*_run.log

# MkDocs build output
site/
